import { test, expect } from '@playwright/test';
import { API_BASE } from '../utils/test-data';

// Replace {{POST_PAYLOAD}} with a valid body for POST /api/{{ROUTE}}
const VALID_PAYLOAD = {{POST_PAYLOAD}};

// Replace {{INVALID_PAYLOAD}} with a body that should fail schema validation (400)
const INVALID_PAYLOAD = {{INVALID_PAYLOAD}};

// Replace {{CROSS_FIELD_PAYLOAD}} with a body that fails a cross-field zod rule (400)
const CROSS_FIELD_PAYLOAD = {{CROSS_FIELD_PAYLOAD}};

test.describe('{{SERVICE_NAME}}', () => {
  test('API: POST /api/{{ROUTE}} — happy path returns 201', async ({ request }) => {
    const response = await request.post(`${API_BASE}/api/{{ROUTE}}`, {
      data: VALID_PAYLOAD,
    });
    expect(response.status()).toBe(201);
    const body = await response.json();
    expect(body).toHaveProperty('id');
    // Add further shape assertions here
  });

  test('API: POST /api/{{ROUTE}} — invalid body returns 400 with errors', async ({ request }) => {
    const response = await request.post(`${API_BASE}/api/{{ROUTE}}`, {
      data: INVALID_PAYLOAD,
    });
    expect(response.status()).toBe(400);
    const body = await response.json();
    expect(body).toHaveProperty('errors');
  });

  test('API: POST /api/{{ROUTE}} — cross-field validation failure returns 400', async ({ request }) => {
    const response = await request.post(`${API_BASE}/api/{{ROUTE}}`, {
      data: CROSS_FIELD_PAYLOAD,
    });
    expect(response.status()).toBe(400);
    const body = await response.json();
    expect(body).toHaveProperty('errors');
  });

  test('API: GET /api/{{ROUTE}} — returns an array', async ({ request }) => {
    const response = await request.get(`${API_BASE}/api/{{ROUTE}}`);
    expect(response.ok()).toBeTruthy();
    const items = await response.json();
    expect(Array.isArray(items)).toBeTruthy();
    // Tolerate pre-existing data — do NOT assert exact length
    expect(items.length).toBeGreaterThanOrEqual(0);
  });
});
