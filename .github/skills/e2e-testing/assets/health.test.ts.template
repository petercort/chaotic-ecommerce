import request from 'supertest';
import express from 'express';

jest.mock('../src/eureka');

// Minimal example — replace with: import { app } from '../src/app';
function buildApp() {
  const app = express();
  app.get('/actuator/health', (_req, res) => res.json({ status: 'UP' }));
  return app;
}

describe('GET /actuator/health', () => {
  it('returns UP', async () => {
    const res = await request(buildApp()).get('/actuator/health');
    expect(res.status).toBe(200);
    expect(res.body).toEqual({ status: 'UP' });
  });
});
